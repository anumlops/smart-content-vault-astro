---
import DashboardLayout from '../layouts/DashboardLayout.astro'
---

<DashboardLayout title="Instagram">
  <div id="app-root"></div>
</DashboardLayout>

<script>
const CATEGORIES = [
  { id: 'life-advice-relationships', label: 'Life Advice & Relationships' },
  { id: 'courses-learning', label: 'Courses & Learning' },
  { id: 'exercise-running', label: 'Exercise & Running' },
]

document.addEventListener('DOMContentLoaded', () => {
  init()
})

function init() {
  const root = document.getElementById('app-root')
  let state = { items: [], filter: 'all', loading: false }

  function render() {
    const filtered = state.filter === 'all'
      ? state.items
      : state.items.filter((i) => i.category === state.filter)

    root.innerHTML = `
      <div class="max-w-4xl mx-auto space-y-8 pb-12">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-xl font-semibold text-white">Instagram</h1>
            <p class="text-sm text-text-dim mt-1">Save and organize Instagram Reels and Posts</p>
          </div>
        </div>

        <div class="bg-surface-muted border border-border rounded-xl p-5">
          <label class="block text-sm font-medium text-text-muted mb-2">Instagram URL</label>
          <div class="flex gap-2">
            <input id="urlInput" type="url" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:border-primary/50" placeholder="https://www.instagram.com/reel/...">
            <button id="extractBtn" class="bg-primary hover:bg-primary-hover text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shrink-0">Extract</button>
          </div>
          <div id="extractStatus" class="text-sm text-blue-400 mt-2"></div>
          <div id="extractError" class="hidden text-sm text-red-400 mt-2"></div>

          <div id="preview" class="hidden mt-4 border border-border rounded-xl overflow-hidden">
            <div class="flex gap-4 p-4">
              <div id="previewThumbWrap" class="hidden w-24 h-24 shrink-0 rounded-lg overflow-hidden bg-surface">
                <img id="previewThumb" class="w-full h-full object-cover" alt="" />
              </div>
              <div class="min-w-0 flex-1">
                <p id="previewTitle" class="text-sm font-medium text-white"></p>
                <p id="previewDesc" class="text-xs text-text-muted mt-1 line-clamp-2"></p>
                <div class="mt-3">
                  <div class="text-xs text-text-dim mb-2">Tag category:</div>
                  <div id="previewCatBtns" class="flex flex-wrap gap-2">
                    <button class="cat-btn-preview px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors" data-value="unassigned">Unassigned</button>
                    ${CATEGORIES.map((c) => `<button class="cat-btn-preview px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors" data-value="${c.id}">${c.label}</button>`).join('')}
                  </div>
                  <button id="saveBtn" class="mt-3 bg-primary hover:bg-primary-hover text-white px-4 py-1.5 rounded-lg text-xs font-medium transition-colors">Save</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2 flex-wrap">
          <button class="filter-btn px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${state.filter === 'all' ? 'bg-primary text-white' : 'bg-surface-muted text-text-muted hover:text-white border border-border'}" data-filter="all">All</button>
          ${CATEGORIES.map((c) => `
            <button class="filter-btn px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${state.filter === c.id ? 'bg-primary text-white' : 'bg-surface-muted text-text-muted hover:text-white border border-border'}" data-filter="${c.id}">${c.label}</button>
          `).join('')}
          ${state.filter !== 'all' ? `<button id="clearFilter" class="text-xs text-text-dim hover:text-white ml-2">Clear</button>` : ''}
        </div>

        <div id="itemsContainer">
          ${state.loading ? '<div class="text-sm text-text-dim text-center py-12">Loading...</div>' : ''}
          ${!state.loading && filtered.length === 0 ? '<div class="text-sm text-text-dim text-center py-12">No saved Instagram content yet</div>' : ''}
          ${!state.loading && filtered.length > 0 ? `
            <div class="grid gap-4">
              ${filtered.map((item) => `
                <div class="bg-surface-muted border border-border rounded-xl overflow-hidden flex gap-4 p-4" data-id="${item.id}">
                  ${item.thumbnail ? `<img src="${item.thumbnail}" class="w-24 h-24 rounded-lg object-cover shrink-0" alt="" />` : '<div class="w-24 h-24 rounded-lg bg-surface shrink-0 flex items-center justify-center text-2xl text-text-dim">🎬</div>'}
                  <div class="min-w-0 flex-1 flex flex-col justify-between">
                    <div>
                      <p class="text-sm font-medium text-white truncate">${item.title || 'Untitled'}</p>
                      <p class="text-xs text-text-muted mt-0.5 line-clamp-2">${item.description || ''}</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-2">
                      <span class="text-xs text-text-dim">Tag:</span>
                      <button class="cat-btn-item px-2.5 py-1 rounded-lg text-xs font-medium border transition-colors ${item.category === 'unassigned' || !item.category ? 'bg-primary text-white border-primary' : 'bg-surface text-text-muted border-border hover:text-white'}" data-id="${item.id}" data-value="unassigned">Unassigned</button>
                      ${CATEGORIES.map((c) => `
                        <button class="cat-btn-item px-2.5 py-1 rounded-lg text-xs font-medium border transition-colors ${item.category === c.id ? 'bg-primary text-white border-primary' : 'bg-surface text-text-muted border-border hover:text-white'}" data-id="${item.id}" data-value="${c.id}">${c.label}</button>
                      `).join('')}
                      <a href="${item.url}" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-primary hover:text-primary-hover underline underline-offset-2 ml-auto">Click Here</a>
                      <span class="text-xs text-text-dim">${new Date(item.createdAt).toLocaleDateString()}</span>
                    </div>
                  </div>
                </div>
              `).join('')}
            </div>
          ` : ''}
        </div>
      </div>
    `

    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        state.filter = btn.dataset.filter
        render()
      })
    })

    document.getElementById('extractBtn').addEventListener('click', handleExtract)

    const clearBtn = document.getElementById('clearFilter')
    if (clearBtn) clearBtn.addEventListener('click', () => { state.filter = 'all'; render() })

    const saveBtn = document.getElementById('saveBtn')
    if (saveBtn) saveBtn.addEventListener('click', handleSave)

    document.querySelectorAll('.cat-btn-preview').forEach((btn) => {
      btn.addEventListener('click', () => {
        previewSelectedCategory = btn.dataset.value
        document.querySelectorAll('.cat-btn-preview').forEach((b) => {
          b.className = `cat-btn-preview px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors ${b.dataset.value === previewSelectedCategory ? 'bg-primary text-white border-primary' : 'bg-surface text-text-muted border-border'}`
        })
      })
    })

    document.querySelectorAll('.cat-btn-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id
        const value = btn.dataset.value
        document.querySelectorAll(`.cat-btn-item[data-id="${id}"]`).forEach((b) => {
          b.className = `cat-btn-item px-2.5 py-1 rounded-lg text-xs font-medium border transition-colors ${b.dataset.value === value ? 'bg-primary text-white border-primary' : 'bg-surface text-text-muted border-border hover:text-white'}`
        })
        handleCategoryUpdate(id, value)
      })
    })
  }

  async function fetchItems() {
    state.loading = true
    render()

    try {
      const params = state.filter !== 'all' ? `?category=${state.filter}` : ''
      const resp = await fetch(`/api/content/instagram${params}`)
      const data = await resp.json()
      state.items = data.items || []
    } catch {
      state.items = []
    }

    state.loading = false
    render()
  }

  let lastPreviewData = null
  let previewSelectedCategory = 'unassigned'

  async function handleExtract() {
    const url = document.getElementById('urlInput').value.trim()
    if (!url) return

    const btn = document.getElementById('extractBtn')
    const status = document.getElementById('extractStatus')
    const error = document.getElementById('extractError')
    const preview = document.getElementById('preview')

    btn.disabled = true
    status.textContent = 'Extracting...'
    error.classList.add('hidden')
    preview.classList.add('hidden')

    try {
      const ac = new AbortController()
      setTimeout(() => ac.abort(), 15000)

      const resp = await fetch('/api/extract/instagram', {
        signal: ac.signal,
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      })

      if (!resp.ok) throw new Error('Extraction failed')

      const data = await resp.json()
      if (!data.success) throw new Error(data.error || 'Extraction failed')

      lastPreviewData = data.data

      const d = data.data
      document.getElementById('previewTitle').textContent = d.title || '(untitled)'
      document.getElementById('previewDesc').textContent = d.description || ''

      const thumbWrap = document.getElementById('previewThumbWrap')
      if (d.thumbnail) {
        document.getElementById('previewThumb').src = d.thumbnail
        thumbWrap.classList.remove('hidden')
      } else {
        thumbWrap.classList.add('hidden')
      }

      preview.classList.remove('hidden')
      status.textContent = ''
    } catch (e) {
      error.textContent = e.message
      error.classList.remove('hidden')
    } finally {
      btn.disabled = false
    }
  }

  async function handleSave() {
    const url = document.getElementById('urlInput').value.trim()
    const category = previewSelectedCategory
    const saveBtn = document.getElementById('saveBtn')
    const status = document.getElementById('extractStatus')

    saveBtn.disabled = true
    status.textContent = 'Saving...'

    try {
      const resp = await fetch('/api/content/instagram', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, category }),
      })

      if (!resp.ok) throw new Error('Save failed')

      status.textContent = 'Saved!'
      document.getElementById('urlInput').value = ''
      document.getElementById('preview').classList.add('hidden')
      lastPreviewData = null
      await fetchItems()
    } catch {
      status.textContent = 'Save failed'
    } finally {
      saveBtn.disabled = false
    }
  }

  async function handleCategoryUpdate(id, category) {
    try {
      await fetch('/api/content/instagram', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, category }),
      })
      await fetchItems()
    } catch {
      // silently fail
    }
  }

  fetchItems()
}
</script>
