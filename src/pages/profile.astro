---
import DashboardLayout from '../layouts/DashboardLayout.astro'
---

<DashboardLayout title="Profile - Smart Content Vault">
  <div class="max-w-lg mx-auto pt-8 text-center">
    <div class="w-20 h-20 rounded-full bg-primary-muted flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </div>
    <h1 class="text-xl font-semibold text-white">Profile</h1>
    <p class="text-sm text-text-muted mt-2">Profile management coming soon</p>
    <a href="/api/auth/logout" class="btn-ghost mt-6">Sign Out</a>
  </div>
</DashboardLayout>
