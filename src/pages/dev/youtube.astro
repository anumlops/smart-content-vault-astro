---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
---

<DashboardLayout title="YouTube Dev Console">
  <div id="dev-root"></div>
</DashboardLayout>

<script>
const API = '/api/extract/youtube'
const MICROSERVICE_URL = 'http://localhost:8001/api/v1/extract'
let useMicroservice = false

function setField(id, val) {
  document.getElementById(id).textContent = val || '(empty)'
}

function setIcon(id, has) {
  const el = document.getElementById(id)
  el.className = `w-5 h-5 rounded-full shrink-0 mt-0.5 ${has ? 'bg-green-500/20 border border-green-500/40' : 'bg-red-500/20 border border-red-500/40'}`
  el.textContent = has ? '\u2713' : '\u2717'
  el.style.display = 'flex'
  el.style.alignItems = 'center'
  el.style.justifyContent = 'center'
  el.style.fontSize = '12px'
  el.style.fontWeight = 'bold'
  el.style.color = has ? '#22c55e' : '#ef4444'
}

document.addEventListener('DOMContentLoaded', () => {
  const root = document.getElementById('dev-root')
  root.innerHTML = `
    <div class="max-w-3xl mx-auto space-y-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold text-white">YouTube Metadata Extraction</h1>
          <p class="text-sm text-text-dim mt-1">Paste a YouTube video URL to extract metadata and test the extraction pipeline</p>
        </div>
        <div class="flex gap-2">
          <a href="/dev/instagram" class="flex items-center gap-1.5 text-sm text-text-muted hover:text-white bg-surface-muted hover:bg-surface-elevated border border-border rounded-lg px-3 py-2 transition-colors">
            Instagram
          </a>
        </div>
      </div>

      <div class="bg-surface-muted border border-border rounded-xl p-5">
        <label class="block text-sm font-medium text-text-muted mb-2">YouTube URL</label>
        <div class="flex gap-2">
          <input id="urlInput" type="url" value="https://www.youtube.com/watch?v=Pdp3p23P-TI" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:border-primary/50" placeholder="https://www.youtube.com/watch?v=...">
          <button id="runBtn" class="bg-primary hover:bg-primary-hover text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shrink-0">Extract</button>
        </div>
        <div class="flex items-center gap-3 mt-3">
          <label class="flex items-center gap-2 text-xs text-text-dim cursor-pointer">
            <input type="checkbox" id="microserviceToggle" class="rounded border-border bg-surface">
            Use microservice directly
          </label>
          <span id="modeLabel" class="text-xs text-blue-400">(Astro API route)</span>
        </div>
        <div id="status" class="text-sm text-blue-400 mt-2"></div>
        <div id="error" class="hidden text-sm text-red-400 mt-2"></div>
      </div>

      <div id="result" class="hidden space-y-6">
        <div class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border flex items-center justify-between">
            <h3 class="text-sm font-semibold text-white">Extracted Metadata</h3>
          </div>
          <div class="p-5 space-y-4">
            <div id="rThumbnailWrap" class="hidden -mx-5 -mt-5 mb-4">
              <img id="rThumbnail" class="w-full max-h-80 object-cover" alt="Thumbnail" />
            </div>

            <div class="grid gap-3">
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconTitle" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">title</div>
                  <div id="rTitle" class="text-sm text-white mt-0.5 break-words"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconDesc" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">description</div>
                  <div id="rDescription" class="text-sm text-text-muted mt-0.5 break-words whitespace-pre-line"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconChannel" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">channel</div>
                  <div id="rChannel" class="text-sm text-text-muted mt-0.5"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconThumbnail" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">thumbnail</div>
                  <div id="rThumbnailUrl" class="text-sm text-text-muted mt-0.5 break-all truncate"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconVideoId" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">videoId</div>
                  <div id="rVideoId" class="text-sm text-text-muted mt-0.5"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border">
            <h3 class="text-sm font-semibold text-white">Full Response</h3>
          </div>
          <div class="p-5">
            <pre id="rRaw" class="text-xs text-text-dim bg-surface border border-border rounded-lg p-4 overflow-x-auto max-h-96 leading-relaxed"></pre>
          </div>
        </div>

        <div class="border border-border rounded-xl p-4 bg-surface-muted">
          <p class="text-sm text-text-dim">
            <strong class="text-white">What to look for:</strong><br>
            &bull; <span class="text-green-400">title</span> &mdash; from YouTube oEmbed API. Should always be present.<br>
            &bull; <span class="text-green-400">description</span> &mdash; from page OG meta tags.<br>
            &bull; <span class="text-green-400">channel</span> &mdash; uploader channel name from oEmbed.<br>
            &bull; <span class="text-green-400">thumbnail</span> &mdash; YouTube thumbnail URL (hqdefault or maxresdefault).<br>
            &bull; Toggle &ldquo;Use microservice directly&rdquo; to test the full Python microservice pipeline (requires <code class="text-xs bg-surface px-1.5 py-0.5 rounded">uvicorn app.main:app --port 8001</code> running).
          </p>
        </div>
      </div>
    </div>
  `

  document.getElementById('microserviceToggle').addEventListener('change', (e) => {
    useMicroservice = e.target.checked
    document.getElementById('modeLabel').textContent = useMicroservice
      ? '(microservice: ' + MICROSERVICE_URL + ')'
      : '(Astro API route)'
  })

  document.getElementById('runBtn').addEventListener('click', run)
})

async function run() {
  const url = document.getElementById('urlInput').value.trim()
  if (!url) return

  const btn = document.getElementById('runBtn')
  const status = document.getElementById('status')
  const error = document.getElementById('error')
  const result = document.getElementById('result')

  btn.disabled = true
  status.textContent = useMicroservice ? 'Calling YouTube microservice...' : 'Fetching YouTube metadata...'
  error.classList.add('hidden')
  result.classList.add('hidden')

  try {
    const endpoint = useMicroservice ? MICROSERVICE_URL : API
    const resp = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    })

    if (!resp.ok) {
      let errMsg = `Server returned ${resp.status}`
      try {
        const text = await resp.text()
        try { const e = JSON.parse(text); errMsg = e.error || e.detail?.error || text } catch { errMsg = text || errMsg }
      } catch {}
      throw new Error(errMsg)
    }

    let data
    try { data = await resp.json() } catch {
      throw new Error('Server returned empty response')
    }

    if (!data.success) throw new Error(data.error || 'Extraction failed')

    const d = data.data

    setField('rTitle', d.title)
    setField('rDescription', d.description)
    setField('rChannel', d.channelName || d.channel_name || '')
    setField('rThumbnailUrl', d.thumbnail)
    setField('rVideoId', d.videoId || d.video_id || '')

    setIcon('iconTitle', !!d.title)
    setIcon('iconDesc', !!d.description)
    setIcon('iconChannel', !!(d.channelName || d.channel_name))
    setIcon('iconThumbnail', !!d.thumbnail)
    setIcon('iconVideoId', !!(d.videoId || d.video_id))

    const thumbWrap = document.getElementById('rThumbnailWrap')
    if (d.thumbnail) {
      document.getElementById('rThumbnail').src = d.thumbnail
      thumbWrap.classList.remove('hidden')
    } else {
      thumbWrap.classList.add('hidden')
    }

    const transcript = d.transcript
    if (transcript && Array.isArray(transcript)) {
      status.textContent = `Transcript available: ${transcript.length} segments`
    } else {
      status.textContent = 'No transcript available (microservice only)'
    }

    document.getElementById('rRaw').textContent = JSON.stringify(d, null, 2)

    result.classList.remove('hidden')
  } catch (e) {
    error.textContent = e.message
    error.classList.remove('hidden')
  } finally {
    btn.disabled = false
  }
}
</script>
