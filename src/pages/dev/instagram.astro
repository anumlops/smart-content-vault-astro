---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
---

<DashboardLayout title="Instagram Dev Console">
  <div id="dev-root"></div>
</DashboardLayout>

<script>
const API = '/api/extract/instagram'
const CATEGORIES = [
  { id: 'life-advice-relationships', label: 'Life Advice & Relationships' },
  { id: 'courses-learning', label: 'Courses & Learning' },
  { id: 'exercise-running', label: 'Exercise & Running' },
]
let selectedCategory = null

document.addEventListener('DOMContentLoaded', () => {
  const root = document.getElementById('dev-root')
  root.innerHTML = `
    <div class="max-w-3xl mx-auto space-y-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold text-white">Instagram OG Extraction</h1>
          <p class="text-sm text-text-dim mt-1">Paste an Instagram Reel or Post URL to validate what OG metadata we can extract</p>
        </div>
        <div class="flex gap-2">
          <a href="/dev/youtube" class="flex items-center gap-1.5 text-sm text-text-muted hover:text-white bg-surface-muted hover:bg-surface-elevated border border-border rounded-lg px-3 py-2 transition-colors">
            YouTube
          </a>
        </div>
      </div>

      <div class="bg-surface-muted border border-border rounded-xl p-5">
        <label class="block text-sm font-medium text-text-muted mb-2">Instagram URL</label>
        <div class="flex gap-2">
          <input id="urlInput" type="url" value="https://www.instagram.com/reel/DW8PkC0AZvb/" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:border-primary/50" placeholder="https://www.instagram.com/reel/...">
          <button id="runBtn" class="bg-primary hover:bg-primary-hover text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shrink-0">Extract</button>
        </div>
        <div id="status" class="text-sm text-blue-400 mt-2"></div>
        <div id="error" class="hidden text-sm text-red-400 mt-2"></div>
      </div>

      <div id="result" class="hidden space-y-6">
        <div class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border flex items-center justify-between">
            <h3 class="text-sm font-semibold text-white">Extracted Metadata</h3>
            <span id="rHtmlSize" class="text-xs text-text-dim"></span>
          </div>
          <div class="p-5 space-y-4">
            <div id="rThumbnailWrap" class="hidden mb-4 flex justify-center">
              <img id="rThumbnail" class="max-w-full max-h-64 rounded-lg object-contain bg-surface" alt="Thumbnail" />
            </div>

            <div class="grid gap-3">
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconTitle" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">og:title</div>
                  <div id="rTitle" class="text-sm text-white mt-0.5 break-words"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconDesc" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">og:description</div>
                  <div id="rDescription" class="text-sm text-text-muted mt-0.5 break-words whitespace-pre-line"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconImage" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">og:image</div>
                  <div id="rImage" class="text-sm text-text-muted mt-0.5 break-all truncate"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconUrl" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">og:url</div>
                  <div id="rOgUrl" class="text-sm text-text-muted mt-0.5 break-all truncate"></div>
                </div>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-surface border border-border">
                <span id="iconCanonical" class="w-5 h-5 rounded-full shrink-0 mt-0.5"></span>
                <div class="min-w-0">
                  <div class="text-xs text-text-dim font-mono">canonical</div>
                  <div id="rCanonical" class="text-sm text-text-muted mt-0.5 break-all truncate"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div id="categorySection" class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border">
            <h3 class="text-sm font-semibold text-white">Tag Category</h3>
          </div>
          <div class="p-5">
            <p class="text-xs text-text-dim mb-3">Select a category to tag this Instagram content:</p>
            <div id="categoryBtns" class="flex flex-wrap gap-2"></div>
            <div id="taggedInfo" class="hidden mt-3 text-xs text-green-400"></div>
          </div>
        </div>

        <div class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border">
            <h3 class="text-sm font-semibold text-white">Full Response</h3>
          </div>
          <div class="p-5">
            <pre id="rRaw" class="text-xs text-text-dim bg-surface border border-border rounded-lg p-4 overflow-x-auto max-h-96 leading-relaxed"></pre>
          </div>
        </div>

        <div class="border border-border rounded-xl p-4 bg-surface-muted">
          <p class="text-sm text-text-dim">
            <strong class="text-white">What to look for:</strong><br>
            • <span class="text-green-400">og:title</span> — the Instagram caption. If empty, Instagram blocked the request.<br>
            • <span class="text-green-400">og:image</span> — the thumbnail URL. If present, you'll see the image above.<br>
            • <span class="text-green-400">HTML size</span> in the header above. Full page ≈ 1.4MB. Stripped ≈ 780KB (no OG data).<br>
            • If all fields are empty, Instagram's CDN detected a non-browser — check <code class="text-xs bg-surface px-1.5 py-0.5 rounded">Sec-Fetch-*</code> headers.
          </p>
        </div>
      </div>
    </div>
  `

  const btn = document.getElementById('runBtn')
  btn.addEventListener('click', run)
})

async function run() {
  const url = document.getElementById('urlInput').value.trim()
  if (!url) return

  const btn = document.getElementById('runBtn')
  const status = document.getElementById('status')
  const error = document.getElementById('error')
  const result = document.getElementById('result')

  btn.disabled = true
  status.textContent = 'Fetching Instagram HTML and extracting OG metadata...'
  error.classList.add('hidden')
  result.classList.add('hidden')

  try {
    const ac = new AbortController()
    const killTimer = setTimeout(() => ac.abort(), 15000)

    const resp = await fetch(API, {
      signal: ac.signal,
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    })
    clearTimeout(killTimer)

    if (!resp.ok) {
      let errMsg = `Server returned ${resp.status}`
      try {
        const text = await resp.text()
        try { const e = JSON.parse(text); errMsg = e.error || e.detail?.error || text } catch { errMsg = text || errMsg }
      } catch {}
      throw new Error(errMsg)
    }

    let data
    try { data = await resp.json() } catch {
      throw new Error('Server returned empty response')
    }

    if (!data.success) throw new Error(data.error || 'Extraction failed')

    const d = data.data

    const setField = (id, val) => {
      document.getElementById(id).textContent = val || '(empty)'
    }
    const setIcon = (id, has) => {
      const el = document.getElementById(id)
      el.className = `w-5 h-5 rounded-full shrink-0 mt-0.5 ${has ? 'bg-green-500/20 border border-green-500/40' : 'bg-red-500/20 border border-red-500/40'}`
      el.textContent = has ? '\u2713' : '\u2717'
      el.style.display = 'flex'
      el.style.alignItems = 'center'
      el.style.justifyContent = 'center'
      el.style.fontSize = '12px'
      el.style.fontWeight = 'bold'
      el.style.color = has ? '#22c55e' : '#ef4444'
    }

    setField('rTitle', d.title)
    setField('rDescription', d.description)
    setField('rImage', d.thumbnail)
    setField('rOgUrl', d.url)
    setField('rCanonical', '(not included in this output format)')

    setIcon('iconTitle', !!d.title)
    setIcon('iconDesc', !!d.description)
    setIcon('iconImage', !!d.thumbnail)
    setIcon('iconUrl', true)
    setIcon('iconCanonical', false)

    const thumbWrap = document.getElementById('rThumbnailWrap')
    if (d.thumbnail) {
      document.getElementById('rThumbnail').src = d.thumbnail
      thumbWrap.classList.remove('hidden')
    } else {
      thumbWrap.classList.add('hidden')
    }

    const sizeEl = document.getElementById('rHtmlSize')
    if (d.htmlSize) {
      const kb = (d.htmlSize / 1024).toFixed(1)
      sizeEl.textContent = `HTML: ${kb} KB`
      sizeEl.className = `text-xs font-mono px-2 py-0.5 rounded-full ${d.htmlSize > 1000000 ? 'text-green-400 bg-green-900/20' : 'text-red-400 bg-red-900/20'}`
    }

    selectedCategory = null
    const categoryBtns = document.getElementById('categoryBtns')
    const taggedInfo = document.getElementById('taggedInfo')
    taggedInfo.classList.add('hidden')
    categoryBtns.innerHTML = CATEGORIES.map(
      (c) => `<button class="cat-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors" data-id="${c.id}">${c.label}</button>`
    ).join('')
    categoryBtns.querySelectorAll('.cat-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedCategory = btn.dataset.id
        categoryBtns.querySelectorAll('.cat-btn').forEach((b) => {
          b.className = b.dataset.id === selectedCategory
            ? 'cat-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-primary text-white border-primary'
            : 'cat-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors bg-surface text-text-muted border-border hover:text-white'
        })
        const label = CATEGORIES.find((c) => c.id === selectedCategory).label
        taggedInfo.textContent = `Tagged as: ${label}`
        taggedInfo.classList.remove('hidden')
      })
    })

    document.getElementById('rRaw').textContent = JSON.stringify(d, null, 2)

    result.classList.remove('hidden')
    status.textContent = ''
  } catch (e) {
    error.textContent = e.message
    error.classList.remove('hidden')
  } finally {
    btn.disabled = false
  }
}
</script>
