---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
---

<DashboardLayout title="Instagram Dev Console">
  <div id="dev-root"></div>
</DashboardLayout>

<script>
const API = '/api/extract/instagram'

document.addEventListener('DOMContentLoaded', () => {
  const root = document.getElementById('dev-root')
  root.innerHTML = `
    <div class="max-w-3xl mx-auto space-y-6">
      <div>
        <h1 class="text-xl font-semibold text-white">Instagram Dev Console</h1>
        <p class="text-sm text-text-dim mt-1">Test Instagram URL extraction, categorization, and tag generation</p>
      </div>

      <div class="bg-surface-muted border border-border rounded-xl p-5">
        <label class="block text-sm font-medium text-text-muted mb-2">Instagram URL</label>
        <div class="flex gap-2">
          <input id="urlInput" type="url" value="https://www.instagram.com/reel/DW8PkC0AZvb/" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:border-primary/50" placeholder="https://www.instagram.com/reel/...">
          <button id="runBtn" class="bg-primary hover:bg-primary-hover text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">Extract</button>
        </div>
        <div id="status"></div>
        <div id="error" class="hidden text-sm text-red-400 mt-2"></div>
      </div>

      <div id="result" class="hidden space-y-4">
        <div class="bg-surface-muted border border-border rounded-xl p-5 space-y-4">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <h2 id="rTitle" class="text-lg font-semibold text-white truncate"></h2>
              <p id="rUrl" class="text-xs text-text-dim mt-1 truncate"></p>
              <p class="text-xs text-text-dim mt-1">
                Platform: <span class="text-text-muted">Instagram</span>
                &middot; Category: <span id="rCategory" class="text-text-muted"></span>
                &middot; Extracted: <span id="rTime" class="text-text-muted"></span>
              </p>
            </div>
          </div>

          <div id="rThumbnailWrap" class="hidden">
            <img id="rThumbnail" class="rounded-lg max-h-64 w-full object-cover" alt="Thumbnail" />
          </div>

          <div>
            <h3 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-2">Description</h3>
            <p id="rDescription" class="text-sm text-text-muted leading-relaxed"></p>
          </div>

          <div>
            <h3 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-2">Tags</h3>
            <div id="rTags" class="flex flex-wrap gap-1.5"></div>
          </div>

          <div>
            <h3 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-2">Raw Metadata</h3>
            <pre id="rRaw" class="text-xs text-text-dim bg-surface border border-border rounded-lg p-3 overflow-x-auto max-h-48"></pre>
          </div>
        </div>
      </div>
    </div>
  `

  const btn = document.getElementById('runBtn')
  btn.addEventListener('click', run)
})

async function run() {
  const url = document.getElementById('urlInput').value.trim()
  if (!url) return

  const btn = document.getElementById('runBtn')
  const status = document.getElementById('status')
  const error = document.getElementById('error')
  const result = document.getElementById('result')

  btn.disabled = true
  status.textContent = 'Fetching and extracting...'
  status.className = 'text-sm text-blue-400 mt-2'
  error.classList.add('hidden')
  result.classList.add('hidden')

  try {
    const resp = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    })

    if (!resp.ok) {
      let errMsg = `Server returned ${resp.status}`
      try {
        const text = await resp.text()
        try { const e = JSON.parse(text); errMsg = e.error || e.detail?.error || text } catch { errMsg = text || errMsg }
      } catch {}
      throw new Error(errMsg)
    }

    let data
    try { data = await resp.json() } catch {
      throw new Error('Server returned empty response')
    }

    if (!data.success) {
      throw new Error(data.error || 'Extraction failed')
    }

    const d = data.data

    document.getElementById('rTitle').textContent = d.title || '(untitled)'
    document.getElementById('rUrl').textContent = d.url || d.canonical_url || ''
    document.getElementById('rCategory').textContent = d.category || '—'
    document.getElementById('rTime').textContent = d.extracted_at ? new Date(d.extracted_at).toLocaleString() : '—'

    const thumbWrap = document.getElementById('rThumbnailWrap')
    if (d.thumbnail) {
      document.getElementById('rThumbnail').src = d.thumbnail
      thumbWrap.classList.remove('hidden')
    } else {
      thumbWrap.classList.add('hidden')
    }

    document.getElementById('rDescription').textContent = d.description || '—'

    const tagsEl = document.getElementById('rTags')
    tagsEl.innerHTML = ''
    if (d.tags?.length) {
      tagsEl.innerHTML = d.tags.map(t =>
        `<span class="bg-blue-900/30 text-blue-300 border border-blue-800/40 rounded-full px-3 py-1 text-xs">${t}</span>`
      ).join(' ')
    } else {
      tagsEl.innerHTML = '<span class="text-text-dim text-xs">No tags generated</span>'
    }

    document.getElementById('rRaw').textContent = JSON.stringify(d, null, 2)

    result.classList.remove('hidden')
    status.textContent = ''
  } catch (e) {
    error.textContent = e.message
    error.classList.remove('hidden')
  } finally {
    btn.disabled = false
  }
}
</script>
