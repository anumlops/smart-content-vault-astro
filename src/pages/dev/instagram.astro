---
import DashboardLayout from '../../layouts/DashboardLayout.astro'
---

<DashboardLayout title="Instagram Dev Console">
  <div id="dev-root"></div>
</DashboardLayout>

<script>
const API = '/api/extract/instagram'

document.addEventListener('DOMContentLoaded', () => {
  const root = document.getElementById('dev-root')
  root.innerHTML = `
    <div class="max-w-3xl mx-auto space-y-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold text-white">Instagram Extractor</h1>
          <p class="text-sm text-text-dim mt-1">Paste an Instagram Reel or Post URL to validate OG metadata extraction</p>
        </div>
        <a href="/dev" class="flex items-center gap-1.5 text-sm text-text-muted hover:text-white bg-surface-muted hover:bg-surface-elevated border border-border rounded-lg px-3 py-2 transition-colors">
          Website Enrichment
        </a>
      </div>

      <div class="bg-surface-muted border border-border rounded-xl p-5">
        <label class="block text-sm font-medium text-text-muted mb-2">Instagram URL</label>
        <div class="flex gap-2">
          <input id="urlInput" type="url" value="https://www.instagram.com/reel/DW8PkC0AZvb/" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2.5 text-sm text-white outline-none focus:border-primary/50" placeholder="https://www.instagram.com/reel/...">
          <button id="runBtn" class="bg-primary hover:bg-primary-hover text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors shrink-0">Extract</button>
        </div>
        <div id="status" class="text-sm text-blue-400 mt-2"></div>
        <div id="error" class="hidden text-sm text-red-400 mt-2"></div>
      </div>

      <div id="result" class="hidden space-y-6">
        <div class="border border-border rounded-xl overflow-hidden">
          <div class="bg-surface-muted px-5 py-3 border-b border-border">
            <h3 class="text-sm font-semibold text-white">Open Graph Metadata</h3>
          </div>
          <div class="p-5 space-y-4">
            <div id="rThumbnailWrap" class="hidden -mx-5 -mt-5 mb-4">
              <img id="rThumbnail" class="w-full max-h-80 object-cover" alt="Thumbnail" />
            </div>
            <div>
              <label class="text-xs font-medium text-text-dim uppercase tracking-wider">og:title</label>
              <p id="rTitle" class="text-base text-white mt-1"></p>
            </div>
            <div>
              <label class="text-xs font-medium text-text-dim uppercase tracking-wider">og:description</label>
              <p id="rDescription" class="text-sm text-text-muted mt-1 leading-relaxed whitespace-pre-line"></p>
            </div>
            <div>
              <label class="text-xs font-medium text-text-dim uppercase tracking-wider">URL</label>
              <p id="rUrl" class="text-sm text-text-muted mt-1 truncate"></p>
            </div>
            <div>
              <label class="text-xs font-medium text-text-dim uppercase tracking-wider">Canonical URL</label>
              <p id="rCanonical" class="text-sm text-text-muted mt-1 truncate"></p>
            </div>
            <div>
              <label class="text-xs font-medium text-text-dim uppercase tracking-wider">Extracted At</label>
              <p id="rTime" class="text-sm text-text-muted mt-1"></p>
            </div>
            <div class="flex items-center gap-2 pt-2">
              <span class="inline-flex items-center gap-1.5 text-xs text-text-dim">
                <span id="rHasTitle" class="w-2 h-2 rounded-full bg-red-500 inline-block"></span>
                og:title
              </span>
              <span class="inline-flex items-center gap-1.5 text-xs text-text-dim">
                <span id="rHasDesc" class="w-2 h-2 rounded-full bg-red-500 inline-block"></span>
                og:description
              </span>
              <span class="inline-flex items-center gap-1.5 text-xs text-text-dim">
                <span id="rHasImage" class="w-2 h-2 rounded-full bg-red-500 inline-block"></span>
                og:image
              </span>
            </div>
          </div>
        </div>

        <details class="border border-border rounded-xl overflow-hidden group">
          <summary class="bg-surface-muted px-5 py-3 border-b border-border cursor-pointer text-sm font-semibold text-white list-none flex items-center justify-between hover:bg-surface-elevated transition-colors">
            <span>Raw JSON</span>
            <span class="text-text-dim group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="p-5">
            <pre id="rRaw" class="text-xs text-text-dim bg-surface border border-border rounded-lg p-4 overflow-x-auto max-h-96 leading-relaxed"></pre>
          </div>
        </details>

        <div class="border border-border rounded-xl p-4 bg-surface-muted">
          <p class="text-sm text-text-dim">
            <strong class="text-white">Validation note:</strong>
            If og:title is empty, Instagram likely detected the request as non-browser.
            Check that all <code class="text-xs bg-surface px-1.5 py-0.5 rounded">Sec-Fetch-*</code> headers are present.
          </p>
        </div>
      </div>
    </div>
  `

  const btn = document.getElementById('runBtn')
  btn.addEventListener('click', run)
})

async function run() {
  const url = document.getElementById('urlInput').value.trim()
  if (!url) return

  const btn = document.getElementById('runBtn')
  const status = document.getElementById('status')
  const error = document.getElementById('error')
  const result = document.getElementById('result')

  btn.disabled = true
  status.textContent = 'Fetching HTML and extracting OG metadata...'
  error.classList.add('hidden')
  result.classList.add('hidden')

  try {
    const ac = new AbortController()
    const killTimer = setTimeout(() => ac.abort(), 15000)

    const resp = await fetch(API, {
      signal: ac.signal,
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    })
    clearTimeout(killTimer)

    if (!resp.ok) {
      let errMsg = `Server returned ${resp.status}`
      try {
        const text = await resp.text()
        try { const e = JSON.parse(text); errMsg = e.error || e.detail?.error || text } catch { errMsg = text || errMsg }
      } catch {}
      throw new Error(errMsg)
    }

    let data
    try { data = await resp.json() } catch {
      throw new Error('Server returned empty response')
    }

    if (!data.success) throw new Error(data.error || 'Extraction failed')

    const d = data.data

    document.getElementById('rTitle').textContent = d.ogTitle || '(empty)'
    document.getElementById('rDescription').textContent = d.ogDescription || '(empty)'
    document.getElementById('rUrl').textContent = d.ogUrl || d.url || ''
    document.getElementById('rCanonical').textContent = d.canonicalUrl || '(none)'
    document.getElementById('rTime').textContent = d.extractedAt ? new Date(d.extractedAt).toLocaleString() : '—'

    const thumbWrap = document.getElementById('rThumbnailWrap')
    if (d.ogImage) {
      document.getElementById('rThumbnail').src = d.ogImage
      thumbWrap.classList.remove('hidden')
    } else {
      thumbWrap.classList.add('hidden')
    }

    const setDot = (id, has) => {
      const el = document.getElementById(id)
      el.className = `w-2 h-2 rounded-full inline-block ${has ? 'bg-green-500' : 'bg-red-500'}`
    }
    setDot('rHasTitle', !!d.ogTitle)
    setDot('rHasDesc', !!d.ogDescription)
    setDot('rHasImage', !!d.ogImage)

    document.getElementById('rRaw').textContent = JSON.stringify(d, null, 2)

    result.classList.remove('hidden')
    status.textContent = ''
  } catch (e) {
    error.textContent = e.message
    error.classList.remove('hidden')
  } finally {
    btn.disabled = false
  }
}
</script>
