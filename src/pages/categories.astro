---
import DashboardLayout from '../layouts/DashboardLayout.astro'
import CategoryCards from '../components/dashboard/CategoryCards.astro'
import { prisma } from '../lib/prisma'

let distribution: Record<string, number> = {}

try {
  const categoryRaw = await prisma.savedContent.groupBy({
    by: ['category'],
    _count: { id: true },
  })

  for (const cat of categoryRaw) {
    if (cat.category) distribution[cat.category] = cat._count.id
  }
} catch {}
---

<DashboardLayout title="Categories - Smart Content Vault">
  <div class="space-y-8 pt-4">
    <div>
      <h1 class="text-2xl font-semibold text-white">Categories</h1>
      <p class="text-sm text-text-muted mt-1">Browse your content by category</p>
    </div>

    {Object.keys(distribution).length > 0 ? (
      <CategoryCards distribution={distribution} />
    ) : (
      <div class="text-center py-20">
        <svg class="w-12 h-12 mx-auto text-text-dim mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <p class="text-text-muted">No categories yet</p>
        <p class="text-sm text-text-dim mt-1">Categories will appear as you save content</p>
      </div>
    )}
  </div>
</DashboardLayout>
