---
import { getDomain, getContentTypeColor, formatRelativeTime } from '../../lib/utils'
import { CATEGORY_META } from '../../types'

export interface Props {
  items: Array<{
    id: string
    url: string
    title: string | null
    contentType: string
    category: string | null
    tags: { id: string; name: string; slug: string }[]
    createdAt: string
  }>
}
---

<div class="space-y-2">
  {Astro.props.items.map((item) => {
    const domain = getDomain(item.url)
    const typeColor = getContentTypeColor(item.contentType)
    const catMeta = item.category ? CATEGORY_META[item.category] : null

    return (
      <div class="flex items-start sm:items-center gap-2 sm:gap-3 p-3 rounded-lg hover:bg-surface-muted/50 transition-colors group">
        <a href={`/content/${item.id}`} class="flex items-start sm:items-center gap-2 sm:gap-3 flex-1 min-w-0">
          <div class="w-8 h-8 rounded-lg bg-surface-muted flex items-center justify-center shrink-0 mt-0.5 sm:mt-0">
            <svg class={`w-4 h-4 ${typeColor}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-sm text-white truncate group-hover:text-primary transition-colors">
              {item.title || domain}
            </p>
            <div class="flex flex-wrap items-center gap-x-1.5 gap-y-0.5 text-xs text-text-muted mt-0.5">
              <span class={typeColor}>{item.contentType}</span>
              <span>·</span>
              <span>{formatRelativeTime(item.createdAt)}</span>
              <span>·</span>
              <span class="truncate max-w-[120px] sm:max-w-none">{domain}</span>
            </div>
          </div>
        </a>
        <div class="flex items-center gap-2 shrink-0 mt-0.5 sm:mt-0">
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-primary hover:text-primary-hover underline underline-offset-2 whitespace-nowrap">
            Click Here
          </a>
          {item.category && (
            <span class="badge text-[10px] bg-primary-muted text-primary border border-primary/20 whitespace-nowrap">
              {catMeta?.emoji} {item.category}
            </span>
          )}
        </div>
      </div>
    )
  })}
</div>
