---
import { getDomain, getContentTypeColor, formatDate } from '../../lib/utils'
import { CATEGORY_META } from '../../types'

export interface Props {
  id: string
  url: string
  title: string | null
  description: string | null
  thumbnailUrl: string | null
  contentType: string
  category: string | null
  tags: { id: string; name: string; slug: string }[]
  createdAt: string
  note?: string | null
  author?: string | null
  publisher?: string | null
  aiSummary?: string | null
  aiTags?: string[]
  keyTakeaways?: string[]
}

const { id, url, title, description, thumbnailUrl, contentType, category, tags, createdAt, note, author, publisher, aiSummary, aiTags, keyTakeaways } = Astro.props
const domain = getDomain(url)
const typeColor = getContentTypeColor(contentType)
const catMeta = category ? CATEGORY_META[category] : null
---

<div class="max-w-3xl mx-auto">
  <div class="mb-4">
    <a href="/dashboard" class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-white transition-colors">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5m7 7l-7-7 7-7" />
      </svg>
      Back
    </a>
  </div>

  <div class="glass-card rounded-xl overflow-hidden">
    {thumbnailUrl ? (
      <div class="aspect-video bg-surface-muted">
        <img src={thumbnailUrl} alt={title || 'Content thumbnail'} class="w-full h-full object-cover" />
      </div>
    ) : (
      <div class="aspect-video bg-surface-muted flex items-center justify-center">
        <svg class="w-16 h-16 text-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" />
        </svg>
      </div>
    )}

    <div class="p-6 space-y-4">
      <div>
        <h1 class="text-xl font-semibold text-white">{title || domain}</h1>
        <div class="flex items-center gap-2 mt-2 text-sm text-text-muted">
          <span class={typeColor}>{contentType}</span>
          <span>·</span>
          <span>{domain}</span>
          {category && (
            <>
              <span>·</span>
              <span class="badge bg-primary-muted text-primary border border-primary/20">
                {catMeta?.emoji} {category}
              </span>
            </>
          )}
        </div>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="badge bg-surface-muted text-text-muted border border-border text-xs">{tag.name}</span>
          ))}
        </div>
      )}

      {description && (
        <p class="text-sm text-text-muted leading-relaxed">{description}</p>
      )}

      <div class="grid grid-cols-2 gap-4 p-4 rounded-lg bg-surface-muted/50">
        <div>
          <span class="text-xs text-text-dim">Saved</span>
          <p class="text-sm text-text-muted">{formatDate(createdAt)}</p>
        </div>
        <div>
          <span class="text-xs text-text-dim">Type</span>
          <p class="text-sm text-text-muted capitalize">{contentType}</p>
        </div>
        {category && (
          <div>
            <span class="text-xs text-text-dim">Category</span>
            <p class="text-sm text-text-muted">{category}</p>
          </div>
        )}
        {publisher && (
          <div>
            <span class="text-xs text-text-dim">Publisher</span>
            <p class="text-sm text-text-muted">{publisher}</p>
          </div>
        )}
      </div>

      <div class="flex items-center gap-2 p-3 rounded-lg bg-surface-muted/30 border border-border">
        <svg class="w-4 h-4 text-text-dim shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <a href={url} target="_blank" rel="noopener noreferrer" class="text-sm text-primary hover:underline truncate">
          {url}
        </a>
      </div>

      {(note) && (
        <div>
          <h3 class="text-sm font-medium text-white mb-2">Your Note</h3>
          <p class="text-sm text-text-muted bg-surface-muted/30 rounded-lg p-3 border border-border">{note}</p>
        </div>
      )}

      {(aiSummary || (aiTags && aiTags.length > 0) || (keyTakeaways && keyTakeaways.length > 0)) && (
        <div class="border-t border-border pt-4 space-y-4">
          <h3 class="text-sm font-medium text-white">AI Enrichment</h3>

          {aiSummary && (
            <div>
              <h4 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-1.5">Summary</h4>
              <p class="text-sm text-text-muted leading-relaxed">{aiSummary}</p>
            </div>
          )}

          {keyTakeaways && keyTakeaways.length > 0 && (
            <div>
              <h4 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-1.5">Key Takeaways</h4>
              <ul class="space-y-1.5">
                {keyTakeaways.map((item) => (
                  <li class="text-sm text-text-muted flex items-start gap-2">
                    <span class="text-primary mt-0.5 shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {aiTags && aiTags.length > 0 && (
            <div>
              <h4 class="text-xs font-medium text-text-dim uppercase tracking-wider mb-1.5">Tags</h4>
              <div class="flex flex-wrap gap-1.5">
                {aiTags.map((tag) => (
                  <span class="badge bg-primary-muted/30 text-primary border border-primary/20 text-xs">{tag}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</div>
