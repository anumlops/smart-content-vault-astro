---
export interface Props {
  error?: string
}
const { error } = Astro.props
---

<div class="glass-card rounded-xl p-6 max-w-lg mx-auto">
  <h2 class="text-lg font-semibold text-white mb-1">Save New Content</h2>
  <p class="text-sm text-text-muted mb-6">Paste a link and save it instantly</p>

  {error && (
    <div class="mb-4 p-3 rounded-lg bg-danger/10 border border-danger/20 text-sm text-danger">
      {error}
    </div>
  )}

  <form method="POST" action="/api/content" class="space-y-4">
    <div>
      <label for="url" class="block text-sm font-medium text-text-muted mb-1.5">URL</label>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <input
          type="url"
          name="url"
          id="url"
          required
          placeholder="https://example.com"
          class="input-field pl-10"
        />
      </div>
      <div id="preview" class="hidden mt-3"></div>
    </div>

    <div>
      <label for="note" class="block text-sm font-medium text-text-muted mb-1.5">Notes (optional)</label>
      <textarea
        name="note"
        id="note"
        rows="3"
        placeholder="Add your notes or thoughts about this content..."
        class="input-field resize-none"
      ></textarea>
    </div>

    <button type="submit" class="btn-primary w-full">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 4v16m8-8H4" />
      </svg>
      Save Content
    </button>
  </form>
</div>

<script>
const input = document.getElementById('url') as HTMLInputElement
const preview = document.getElementById('preview') as HTMLDivElement
let debounceTimer: ReturnType<typeof setTimeout>

input.addEventListener('input', () => {
  clearTimeout(debounceTimer)
  const url = input.value.trim()

  if (!url.includes('instagram.com')) {
    preview.classList.add('hidden')
    return
  }

  debounceTimer = setTimeout(async () => {
    preview.innerHTML = '<div class="flex items-center gap-2 text-sm text-text-dim"><svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="80" stroke-dashoffset="60"/></svg>Fetching preview...</div>'
    preview.classList.remove('hidden')

    try {
      const resp = await fetch('/api/extract/instagram', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      })
      const data = await resp.json()
      if (!data.success || !data.data) {
        preview.classList.add('hidden')
        return
      }

      const d = data.data
      preview.innerHTML = `
        <div class="flex gap-3 p-3 rounded-lg border border-border bg-surface-muted">
          ${d.thumbnail
            ? `<img src="${d.thumbnail.replace(/&/g, '&amp;')}" class="w-20 h-20 rounded-lg object-cover shrink-0" alt="" />`
            : ''
          }
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-white truncate">${d.title || '(untitled)'}</p>
            <p class="text-xs text-text-muted mt-0.5 line-clamp-2">${d.description || ''}</p>
            <div class="flex items-center gap-2 mt-2">
              <span class="text-xs bg-primary-muted text-primary rounded-full px-2 py-0.5 font-medium">${d.category || 'Other'}</span>
              ${(d.tags || []).slice(0, 3).map((t: string) =>
                `<span class="text-xs bg-indigo-900/30 text-indigo-300 rounded-full px-2 py-0.5">${t}</span>`
              ).join('')}
            </div>
          </div>
        </div>
      `
    } catch {
      preview.classList.add('hidden')
    }
  }, 800)
})
</script>
