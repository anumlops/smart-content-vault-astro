---
export interface Props {
  error?: string
}
const { error } = Astro.props
---

<div class="glass-card rounded-xl p-6 max-w-lg mx-auto">
  <h2 class="text-lg font-semibold text-white mb-1">Save New Content</h2>
  <p class="text-sm text-text-muted mb-6">Paste a link and save it instantly</p>

  {error && (
    <div class="mb-4 p-3 rounded-lg bg-danger/10 border border-danger/20 text-sm text-danger">
      {error}
    </div>
  )}

  <form method="POST" action="/api/content" class="space-y-4">
    <div>
      <label for="url" class="block text-sm font-medium text-text-muted mb-1.5">URL</label>
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <input
          type="url"
          name="url"
          id="url"
          required
          placeholder="https://example.com"
          class="input-field pl-10"
        />
      </div>
    </div>

    <div>
      <label for="note" class="block text-sm font-medium text-text-muted mb-1.5">Notes (optional)</label>
      <textarea
        name="note"
        id="note"
        rows="3"
        placeholder="Add your notes or thoughts about this content..."
        class="input-field resize-none"
      ></textarea>
    </div>

    <div id="instagramCategoryWrap" class="hidden">
      <label class="block text-sm font-medium text-text-muted mb-2">Instagram Category</label>
      <div id="instagramCategoryBtns" class="flex flex-wrap gap-2">
        <label class="cat-option cursor-pointer">
          <input type="radio" name="category" value="unassigned" checked class="hidden">
          <span class="block px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors">Unassigned</span>
        </label>
        <label class="cat-option cursor-pointer">
          <input type="radio" name="category" value="life-advice-relationships" class="hidden">
          <span class="block px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors">Life Advice & Relationships</span>
        </label>
        <label class="cat-option cursor-pointer">
          <input type="radio" name="category" value="courses-learning" class="hidden">
          <span class="block px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors">Courses & Learning</span>
        </label>
        <label class="cat-option cursor-pointer">
          <input type="radio" name="category" value="exercise-running" class="hidden">
          <span class="block px-3 py-1.5 rounded-lg text-xs font-medium border border-border bg-surface text-text-muted transition-colors">Exercise & Running</span>
        </label>
      </div>
    </div>

    <button type="submit" class="btn-primary w-full">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 4v16m8-8H4" />
      </svg>
      Save Content
    </button>
  </form>
</div>

<script>
const urlInput = document.getElementById('url')
const catWrap = document.getElementById('instagramCategoryWrap')
const catRadios = document.querySelectorAll('input[name="category"]')

urlInput.addEventListener('input', () => {
  const val = urlInput.value.trim().toLowerCase()
  if (/instagram\.com\/(reel|p)\//.test(val)) {
    catWrap.classList.remove('hidden')
  } else {
    catWrap.classList.add('hidden')
    catRadios.forEach((r) => { if (r.value === 'unassigned') r.checked = true })
  }
})

document.querySelectorAll('.cat-option input').forEach((radio) => {
  radio.addEventListener('change', () => {
    document.querySelectorAll('.cat-option span').forEach((s) => {
      s.className = 'block px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors bg-surface text-text-muted border-border'
    })
    if (radio.checked && radio.value !== 'unassigned') {
      radio.parentElement.querySelector('span').className = 'block px-3 py-1.5 rounded-lg text-xs font-medium border transition-colors bg-primary text-white border-primary'
    }
  })
})
</script>


