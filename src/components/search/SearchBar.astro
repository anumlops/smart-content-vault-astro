---
export interface Props {
  query?: string
}

const { query = '' } = Astro.props
---

<form method="GET" action="/search" class="relative">
  <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
  </svg>
  <input
    type="search"
    name="q"
    value={query}
    placeholder="Search your content archive..."
    class="input-field pl-10 pr-4 py-3 text-base"
    autofocus
  />
</form>
