---
const navItems = [
  { href: '/dashboard', label: 'Home', icon: 'home' },
  { href: '/categories', label: 'Categories', icon: 'categories' },
  { href: '/instagram', label: 'Instagram', icon: 'instagram' },
  { href: '/search', label: 'Search', icon: 'search' },
  { href: '/timeline', label: 'Timeline', icon: 'timeline' },
  { href: '/profile', label: 'Profile', icon: 'profile' },
  { href: '/dev', label: 'Dev', icon: 'dev' },
]
---

<aside class="hidden lg:flex lg:flex-col w-56 min-h-screen border-r border-border bg-surface shrink-0">
  <div class="p-4 border-b border-border">
    <a href="/dashboard" class="flex items-center gap-2 text-sm font-semibold text-white">
      <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      Limo
    </a>
  </div>
  <nav class="flex-1 p-3 space-y-1">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="flex items-center gap-3 px-3 py-2 text-sm text-text-muted hover:text-white hover:bg-surface-muted rounded-lg transition-colors"
      >
        <span class="w-4 h-4 flex items-center justify-center">
          {item.icon === 'home' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>}
          {item.icon === 'categories' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>}
          {item.icon === 'instagram' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>}
          {item.icon === 'search' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>}
          {item.icon === 'timeline' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
          {item.icon === 'profile' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>}
          {item.icon === 'dev' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>}
        </span>
        {item.label}
      </a>
    ))}
  </nav>
  <div class="p-3 border-t border-border">
    <a href="/api/auth/logout" class="flex items-center gap-3 px-3 py-2 text-sm text-text-muted hover:text-white hover:bg-surface-muted rounded-lg transition-colors">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
      </svg>
      Sign Out
    </a>
  </div>
</aside>
