---
const currentPage = Astro.url.pathname
---

<header class="sticky top-0 z-40 border-b border-border bg-surface/80 backdrop-blur-md">
  <div class="flex items-center justify-between h-14 px-4 sm:px-6">
    <div class="flex items-center gap-3 lg:hidden">
      <a href="/dashboard" class="flex items-center gap-2 text-sm font-semibold text-white">
        <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </a>
    </div>
    <div class="flex-1 max-w-md mx-4">
      <a
        href="/search"
        class="flex items-center gap-2 px-3 py-1.5 text-sm text-text-muted bg-surface-muted/50 border border-border rounded-lg hover:border-border-hover transition-colors"
      >
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" />
        </svg>
        <span>Search your content archive...</span>
        <span class="ml-auto hidden sm:inline text-xs text-text-dim bg-surface px-1.5 py-0.5 rounded border border-border">Ctrl+K</span>
      </a>
    </div>
    <div class="flex items-center gap-2">
      <button class="btn-icon" title="Toggle dark mode">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </div>
</header>
